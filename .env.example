FVQL_ENVIRONMENT=development
FVQL_DEBUG=false
FVQL_API_PREFIX=/api/v1
FVQL_DATABASE_URL=sqlite:///./factory_vision.db
FVQL_LOG_LEVEL=INFO
FVQL_LOG_FILE=logs/backend.jsonl
FVQL_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001"]
